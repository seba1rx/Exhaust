{
    "name": "seba1rx/exhaust",
    "description": "Exhaust — minimalist SPA-oriented PHP framework",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Sebastián Basilio Arenas",
            "email": "seba.1rx@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Exhaust\\": "src/"
        },
        "files": [
            "src/globalScopeFunctions.php"
        ]
    },
    "require": {
        "php": ">=8.4",
        "psr/log": "^3.0",
        "league/uri": "^7.0",
        "league/uri-components": "^7.0",
        "illuminate/database": "^11.0 | ^12.0",
        "nelexa/zip": "^4.0",
        "mnapoli/silly": "^1.0",
        "phpmailer/phpmailer": "^6.0",
        "seba1rx/sessionadmin": "dev-main",
        "twig/twig": "^3.0",
        "scotteh/php-dom-wrapper": "^3.0",
        "smarty/smarty": "^5.5",
        "illuminate/view": "^11.0 | ^12.0",
        "league/plates": "^3.0",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.1"
    },
    "extra": {
        "exhaust": {
            "stubs": "stubs/"
        }
    }
}
